// ClientConnect Portal — Prisma schema
// See docs/01-data-model.md for rationale, ERD, and cascade policy.
// REVIEW fixes baked in:
//   - User.tokenVersion (REVIEW-2.md §3.3) — invalidates JWTs on role change
//   - User.unreadNotifications (docs/14-notifications.md) — denormalized badge count
//   - Session model (docs/02-authentication.md) — refresh-token revocation

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────
// Users & Auth
// ─────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  role          UserRole
  name          String

  // Bumped on role change or force-logout. Embedded in access token;
  // DAL rejects tokens with stale versions. (REVIEW-2.md §3.3)
  tokenVersion  Int      @default(0)

  // Block/unblock users without deleting accounts.
  isActive      Boolean  @default(true)

  // GDPR right-to-erasure (Art 17): set when PII is anonymized.
  anonymizedAt  DateTime?

  // Denormalized for cheap navbar-badge reads. (docs/14-notifications.md)
  unreadNotifications  Int       @default(0)
  lastNotificationSeenAt DateTime?

  // SSO provider (null = password-based auth)
  ssoProviderId String?
  ssoProvider   SsoProvider? @relation(fields: [ssoProviderId], references: [id])

  // TOTP-based 2FA (RFC 6238). totpSecret stores the enabled base32 secret.
  totpEnabled        Boolean   @default(false)
  totpSecret         String?   // active base32 secret (present when totpEnabled)
  totpPendingSecret  String?   // base32 secret during enrollment, before verification
  backupCodes        String[]  // SHA-256 hashes of recovery codes

  // Optional 1:1 profile relations
  client        Client?
  teamMember    TeamMember?

  // Relations
  comments      Comment[]      @relation("CommentAuthor")
  auditLogs     AuditLog[]
  sessions      Session[]
  notifications Notification[]
  uploadedFiles File[]        @relation("FileUploader")
  passwordResetTokens PasswordResetToken[]
  erasureRequest      ErasureRequest?

  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?

  @@index([role])
  @@index([isActive])
  @@index([deletedAt])
  @@index([ssoProviderId])
}

enum UserRole {
  SUPER_ADMIN
  TEAM_MEMBER
  CLIENT
}

model Session {
  // For refresh-token rotation + revocation. Access tokens are stateless;
  // refresh tokens are looked up here on each /refresh.
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash  String    @unique
  expiresAt         DateTime
  revokedAt         DateTime?
  ip                String?
  userAgent         String?
  createdAt         DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ─────────────────────────────────────────────────────────────────
// SSO / SAML / OIDC Providers
// ─────────────────────────────────────────────────────────────────

model SsoProvider {
  id              String   @id @default(cuid())
  name            String
  providerType    String   // "saml" | "oidc"
  isActive        Boolean  @default(true)

  // SAML-specific
  idpEntityId     String?  // Entity ID from IdP metadata
  idpSsoUrl       String?  // IdP SSO endpoint (HTTP-Redirect or HTTP-POST)
  idpCertificate  String?  // x509 certificate for signature verification
  spEntityId      String   @default("urn:connectio:sso") // Our SP entity ID
  spAcsUrl        String?  // Auto-computed at runtime from base URL

  // OIDC-specific
  oidcIssuer      String?  // e.g. https://login.microsoftonline.com/{tenant}/v2.0
  oidcDiscoveryUrl String? // Well-known OpenID configuration URL
  oidcClientId    String?  // OIDC client ID
  oidcClientSecret String? // OIDC client secret

  // Attribute mapping (JSON string — maps IdP claims to User fields)
  // e.g. {"email": "email", "name": "name", "role": "groups"}
  attributeMapping Json?

  // JIT provisioning: create user on first successful SSO login
  jitProvisioning Boolean  @default(true)
  defaultRole     UserRole @default(TEAM_MEMBER)

  users           User[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive])
  @@index([providerType])
}

// ─────────────────────────────────────────────────────────────────
// SCIM API Keys  (for identity provider provisioning)
// ─────────────────────────────────────────────────────────────────

model ScimApiKey {
  id          String    @id @default(cuid())
  name        String    // human-readable label
  keyHash     String    // SHA-256 of the bearer token
  prefix      String    // first 8 chars of the key for identification
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdBy   String
  createdAt   DateTime  @default(now())

  @@index([keyHash])
  @@index([isActive])
}

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    @unique // SHA-256 of the bearer token
  prefix      String    // first 8 chars of the key for ID
  permissions String[]  // e.g. ['read:submissions', 'read:clients']
  scopes      String[]  // resource scopes (client IDs, form IDs)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdBy   String
  createdAt   DateTime  @default(now())

  @@index([keyHash])
  @@index([isActive])
}

// ─────────────────────────────────────────────────────────────────
// Password Reset Tokens
// ─────────────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ─────────────────────────────────────────────────────────────────
// Invites  (pre-registration; consumed at sign-up)
// ─────────────────────────────────────────────────────────────────

model Invite {
  id           String      @id @default(cuid())
  email        String
  companyName  String
  contactName  String
  slug         String      @unique
  createdBy    String
  status       InviteStatus @default(OPEN)
  consumedBy   String?
  expiresAt    DateTime
  createdAt    DateTime    @default(now())

  client       Client?

  @@index([status])
  @@index([email])
}

enum InviteStatus {
  OPEN
  CONSUMED
  REVOKED
  EXPIRED
}

// ─────────────────────────────────────────────────────────────────
// Clients & Team
// ─────────────────────────────────────────────────────────────────

model Client {
  id            String           @id @default(cuid())
  userId        String           @unique
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  inviteId      String?          @unique
  invite        Invite?          @relation(fields: [inviteId], references: [id], onDelete: SetNull)

  companyName   String
  contactName   String
  uniqueSlug    String           @unique

  projectBrief  String?
  budget        String?
  timeline      String?

  submissions   Submission[]
  comments      Comment[]
  files         File[]           @relation("ClientFiles")
  assignments   TeamAssignment[]
  settings      ClientSettings?

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  deletedAt     DateTime?

  @@index([uniqueSlug])
  @@index([deletedAt])
}

model ClientSettings {
  id            String   @id @default(cuid())
  clientId      String   @unique
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  brandColor    String?  // Primary accent color (hex)
  logoUrl       String?  // Logo image URL for the portal header
  faviconUrl    String?  // Favicon URL
  portalTitle   String?  // Custom title shown in sidebar header
  customDomain  String?  // White-label domain
  customCss     String?  // Arbitrary CSS overrides
  hideBranding  Boolean  @default(false) // Hide "Powered by ClientConnect"

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TeamMember {
  id            String           @id @default(cuid())
  userId        String           @unique
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  department    String?
  assignments   TeamAssignment[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  deletedAt     DateTime?

  @@index([deletedAt])
}

model TeamAssignment {
  id            String     @id @default(cuid())
  teamMemberId  String
  teamMember    TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  clientId      String
  client        Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignedAt    DateTime   @default(now())

  @@unique([teamMemberId, clientId])
  @@index([clientId])
}

// ─────────────────────────────────────────────────────────────────
// Forms & Submissions
// ─────────────────────────────────────────────────────────────────

model Form {
  id            String       @id @default(cuid())
  title         String
  description   String?
  formSchema    Json
  isActive      Boolean      @default(true)
  submissions   Submission[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  @@index([isActive])
  @@index([deletedAt])
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

model Submission {
  id            String           @id @default(cuid())
  clientId      String
  client        Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  formId        String
  form          Form             @relation(fields: [formId], references: [id])
  formData      Json
  status        SubmissionStatus @default(DRAFT)

  files         File[]
  comments      Comment[]

  submittedAt   DateTime?
  reviewedBy    String?
  reviewedAt    DateTime?

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  deletedAt     DateTime?

  @@unique([clientId, formId])
  @@index([status])
  @@index([formId])
  @@index([clientId])
  @@index([deletedAt])
}

// ─────────────────────────────────────────────────────────────────
// Files
// ─────────────────────────────────────────────────────────────────

model File {
  id            String       @id @default(cuid())
  submissionId  String?
  submission    Submission?  @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  clientId      String
  client        Client       @relation("ClientFiles", fields: [clientId], references: [id], onDelete: Cascade)

  storageKey    String
  originalName  String
  mimeType      String
  size          BigInt
  checksum      String
  uploadedById  String
  uploadedBy    User         @relation("FileUploader", fields: [uploadedById], references: [id])

  uploadedAt    DateTime     @default(now())
  deletedAt     DateTime?

  @@index([submissionId])
  @@index([clientId])
  @@index([deletedAt])
}

// ─────────────────────────────────────────────────────────────────
// Comments
// ─────────────────────────────────────────────────────────────────

model Comment {
  id            String      @id @default(cuid())
  clientId      String
  client        Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  authorId      String
  author        User        @relation("CommentAuthor", fields: [authorId], references: [id])

  submissionId  String?
  submission    Submission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)

  message       String
  isInternal    Boolean     @default(false)

  parentId      String?
  parent        Comment?    @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies       Comment[]   @relation("CommentReplies")

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  @@index([clientId, createdAt])
  @@index([submissionId])
  @@index([authorId])
  @@index([deletedAt])
}

// ─────────────────────────────────────────────────────────────────
// Notifications  (docs/14-notifications.md)
// ─────────────────────────────────────────────────────────────────

model Notification {
  id            String           @id @default(cuid())
  recipientId   String
  recipient     User             @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  type          NotificationType
  clientId      String?
  submissionId  String?
  commentId     String?
  title         String
  body          String
  href          String
  payload       Json?
  readAt        DateTime?
  emailedAt     DateTime?
  createdAt     DateTime         @default(now())

  @@index([recipientId, readAt, createdAt])
  @@index([recipientId, createdAt])
}

enum NotificationType {
  INVITE_CREATED
  INVITE_CONSUMED
  INVITE_EXPIRED
  SUBMISSION_DRAFTED
  SUBMISSION_SUBMITTED
  SUBMISSION_IN_REVIEW
  SUBMISSION_CHANGES_REQUESTED
  SUBMISSION_APPROVED
  SUBMISSION_REJECTED
  COMMENT_POSTED_EXTERNAL
  COMMENT_POSTED_EXTERNAL_BY_CLIENT
  COMMENT_POSTED_INTERNAL
  COMMENT_REPLY
  FILE_UPLOADED_CLIENT
  FILE_UPLOADED_TEAM
  TEAM_MEMBER_ASSIGNED
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  USER_BLOCKED
  USER_UNBLOCKED
  USER_PASSWORD_RESET_BY_ADMIN
  SYSTEM_ERROR
  DATA_EXPORT_REQUESTED
  DATA_EXPORT_COMPLETED
  ERASURE_REQUESTED
  ERASURE_APPROVED
  ERASURE_DENIED
  AUDIT_CHAIN_BROKEN
  SSO_PROVIDER_CREATED
  SSO_PROVIDER_UPDATED
  SSO_PROVIDER_DELETED
  SSO_LOGIN_SUCCESS
  SSO_LOGIN_FAILED
  SCIM_USER_PROVISIONED
  SCIM_USER_DEPROVISIONED
  FORM_ASSIGNED
}

// ─────────────────────────────────────────────────────────────────
// Webhooks & audit forwarding
// ─────────────────────────────────────────────────────────────────

model Webhook {
  id              String              @id @default(cuid())
  name            String
  url             String
  secret          String?
  isActive        Boolean             @default(true)
  events          String[]            // subscribed events or ["*"] for all
  retryCount      Int                 @default(3)
  timeoutSec      Int                 @default(10)
  lastDeliveredAt DateTime?
  lastStatus      Int?
  lastError       String?
  createdBy       String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  deliveries      WebhookDelivery[]

  @@index([isActive])
}

model WebhookDelivery {
  id            String   @id @default(cuid())
  webhookId     String
  webhook       Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  event         String
  payload       Json
  status        Int?
  responseBody  String?
  error         String?
  attempt       Int      @default(1)
  deliveredAt   DateTime?
  createdAt     DateTime @default(now())

  @@index([webhookId, createdAt])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────
// Email logs & templates  (transactional email audit trail)
// ─────────────────────────────────────────────────────────────────

model EmailLog {
  id          String   @id @default(cuid())
  to          String
  subject     String
  category    String?  // 'welcome' | 'invite' | 'password_reset' | 'notification' | etc.
  provider    String?  // 'gmail-oauth2' | 'gmail-app-password' | 'smtp' | 'stub'
  status      String   @default("pending") // 'sent' | 'failed' | 'skipped'
  error       String?
  htmlBody    String?  // truncated to 2000 chars
  textBody    String?  // truncated to 2000 chars
  attempt     Int      @default(1)
  deliveredAt DateTime?
  createdAt   DateTime @default(now())

  @@index([to, createdAt])
  @@index([category, createdAt])
  @@index([status])
}

model EmailTemplate {
  id          String   @id @default(cuid())
  key         String   @unique  // 'welcome' | 'invite' | 'password_reset' | 'notification'
  name        String
  category    String?
  subject     String
  htmlBody    String?
  textBody    String?
  variables   String?  // comma-separated variable names, e.g. "name,company,link"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
}

// ─────────────────────────────────────────────────────────────────
// Audit Log  (append-only; tamper-evidence comes in REVIEW-4.md §6.1)
// ─────────────────────────────────────────────────────────────────

model AuditLog {
  id            String    @id @default(cuid())
  userId        String?
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  action        String
  resource      String
  resourceId    String
  changes       Json?
  ip            String?
  userAgent     String?
  previousHash  String?   // SHA-256 of the preceding entry (null for genesis entry)
  hash          String?   // SHA-256 of this entry; tamper-evident chain (set by writeAudit)
  createdAt     DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@index([previousHash])
}

// Tracks GDPR right-to-erasure requests (Art 17) for audit trail.
model ErasureRequest {
  id            String       @id @default(cuid())
  userId        String       @unique
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestedBy   String       // userId who submitted the request
  reason        String?      // optional reason for erasure
  status        ErasureStatus @default(PENDING)
  reviewedBy    String?      // admin who approved/denied
  reviewedAt    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([status])
}

enum ErasureStatus {
  PENDING
  APPROVED
  DENIED
}

// ─────────────────────────────────────────────────────────────────
// System Settings  (key-value store for runtime-configurable knobs)
// ─────────────────────────────────────────────────────────────────

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@index([updatedAt])
}
